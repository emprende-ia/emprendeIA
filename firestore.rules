/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-specific data
 * (profiles and search history). Suppliers are publicly readable, but only
 * writeable with an `ownerId` that matches the authenticated user's UID.
 *
 * Data Structure:
 * - /suppliers/{supplierId}: Stores supplier profiles, publicly readable, owner-writeable.
 * - /users/{userId}: Stores user profiles, accessible only by the user.
 * - /users/{userId}/searchHistory/{searchId}: Stores user search history, accessible only by the user.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Read-only collections are not used; instead, public read access is granted to the suppliers collection.
 * - Ambiguous relationships default to owner-only access.
 *
 * Denormalization for Authorization:
 *  - The supplier documents does not currently denormalize the `ownerId`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user's UID matches the resource's ownerId.
     */
    function isResourceOwner(resourceOwnerId) {
      return request.auth.uid == resourceOwnerId;
    }

    /**
     * @description Checks if the authenticated user's UID matches the resource's ownerId and that the resource exists.
     */
    function isExistingOwner(resourceOwnerId) {
      return isResourceOwner(resourceOwnerId) && resource != null;
    }

    /**
     * @description Rules for the /suppliers collection.
     * @path /suppliers/{supplierId}
     * @allow (get, list): Any user can read supplier information.
     * @allow (create): Only authenticated users can create a supplier, the 'ownerId' field must match the authenticated user's UID.
     * @allow (update, delete): Only the owner of the supplier can update or delete it, verifying that the document exists.
     * @deny (create):  If the 'ownerId' field does not match the authenticated user's UID.
     * @deny (update, delete): If the authenticated user is not the owner of the supplier or the supplier does not exist.
     * @principle Public read, owner-only write for suppliers.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if isSignedIn() // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Rules for the /users collection.
     * @path /users/{userId}
     * @allow (get): Only the user can read their own profile.
     * @allow (create): Only the user can create their own profile, validating that the userId matches the authenticated user's UID.
     * @allow (update, delete): Only the user can update or delete their own profile, verifying that the document exists.
     * @deny (get): If the authenticated user is not the owner of the profile.
     * @deny (create): If the userId does not match the authenticated user's UID.
     * @deny (update, delete): If the authenticated user is not the owner of the profile or the profile does not exist.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/searchHistory collection.
     * @path /users/{userId}/searchHistory/{searchId}
     * @allow (get, list): Only the user can read their own search history.
     * @allow (create): Only the user can create their own search history entries.
     * @allow (update, delete): Only the user can update or delete their own search history entries, verifying that the document exists.
     * @deny (get, list): If the authenticated user is not the owner.
     * @deny (create): If the authenticated user is not the owner.
     * @deny (update, delete): If the authenticated user is not the owner or the entry does not exist.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/searchHistory/{searchId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}