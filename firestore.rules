/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user-specific data and allows public read access to supplier data.
 *
 * Data Structure:
 * - /suppliers/{supplierId}: Publicly readable supplier information.
 * - /users/{userId}: Publicly readable user profile information.
 * - /users/{userId}/searchHistory/{searchId}: Private search history for each user.
 * - /users/{userId}/transactions/{transactionId}: Private transaction records for each user.
 * - /users/{userId}/learningPaths/{pathId}: Private, personalized learning paths for each user.
 *
 * Key Security Decisions:
 * - Users can only create, read, update, and delete their own search history, transactions, and learning paths.
 * - Listing of user subcollections (searchHistory, transactions, learningPaths) is allowed only for the owner.
 * - Supplier data is publicly readable.
 *
 * Denormalization for Authorization:
 * - User ownership is enforced by matching the `userId` path segment with the authenticated user's `uid`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to supplier data.
     * @path /suppliers/{supplierId}
     * @allow (get, list): Any user can read supplier data.
     * @allow (create, update, delete): No one can create, update, or delete supplier data through client-side rules.  These operations should be handled by trusted environments.
     * @deny (create, update, delete): Attempts to create, update, or delete a supplier document.
     * @principle Public read, restricted write access for supplier data.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to user profile data.
     * @path /users/{userId}
     * @allow (get, list): Any user can read user profile data.
     * @allow (create): A user can create their own profile if the userId matches their auth UID.
     * @allow (update): A user can update their own profile if the userId matches their auth UID.
     * @allow (delete): A user can delete their own profile if the userId matches their auth UID.
     * @deny (create, update, delete): Attempts to create, update, or delete a user document with a mismatched userId.
     * @principle Public read, owner-only write access for user profiles.
     */
    match /users/{userId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Enforces user-ownership for search history entries.
     * @path /users/{userId}/searchHistory/{searchId}
     * @allow (create): A user can create a search history entry under their own user ID.
     * @allow (get, list): A user can read their own search history entries.
     * @allow (update): A user can update their own search history entry.
     * @allow (delete): A user can delete their own search history entry.
     * @deny (create, get, list, update, delete): Attempts to access search history with a mismatched userId.
     * @principle Enforces document ownership for search history.
     */
    match /users/{userId}/searchHistory/{searchId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for transaction records.
     * @path /users/{userId}/transactions/{transactionId}
     * @allow (create): A user can create a transaction record under their own user ID.
     * @allow (get, list): A user can read their own transaction records.
     * @allow (update): A user can update their own transaction record.
     * @allow (delete): A user can delete their own transaction record.
     * @deny (create, get, list, update, delete): Attempts to access transactions with a mismatched userId.
     * @principle Enforces document ownership for transactions.
     */
    match /users/{userId}/transactions/{transactionId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for learning paths.
     * @path /users/{userId}/learningPaths/{pathId}
     * @allow (create): A user can create a learning path under their own user ID.
     * @allow (get, list): A user can read their own learning paths.
     * @allow (update): A user can update their own learning path.
     * @allow (delete): A user can delete their own learning path.
     * @deny (create, get, list, update, delete): Attempts to access learning paths with a mismatched userId.
     * @principle Enforces document ownership for learning paths.
     */
    match /users/{userId}/learningPaths/{pathId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the request is made by the owner of the document.
     * @param {string} userId The user ID to check against.
     * @return {boolean} True if the user ID matches the authenticated user's ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the request is made by the owner of an EXISTING document.
     * @param {string} userId The user ID to check against.
     * @return {boolean} True if the user ID matches the authenticated user's ID and the document exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}