/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user-specific data while allowing public read access to supplier information.
 *
 * Data Structure:
 * - /suppliers/{supplierId}: Public supplier data.
 * - /users/{userId}: Public user profile information.
 * - /users/{userId}/searchHistory/{searchId}: User-specific search history.
 * - /users/{userId}/transactions/{transactionId}: User-specific financial transactions.
 * - /users/{userId}/learningPaths/{pathId}: User-specific learning paths.
 *
 * Key Security Decisions:
 * - Users can only create, read, update, and delete their own search history, transactions, and learning paths.
 * - Suppliers are publicly readable, but write access is not defined in this prototype and must be secured separately.
 * - User profiles are publicly readable, but write access is not defined in this prototype and must be secured separately.
 * - Listing of user subcollections (searchHistory, transactions, learningPaths) is allowed only for the owner.
 *
 * Denormalization for Authorization:
 * - User-owned documents under `/users/{userId}` are validated on creation to ensure that the `userId` path segment matches an `id` field within the document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants public read access to supplier data. Write access is not defined in this prototype.
     * @path /suppliers/{supplierId}
     * @allow (get, list): Any user can read supplier data.
     * @deny (create, update, delete): Writes are not permitted.
     * @principle Allows public read access to supplier information.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Grants public read access to user profile data. Write access is not defined in this prototype.
     * @path /users/{userId}
     * @allow (get, list): Any user can read user profile data.
     * @deny (create, update, delete): Writes are not permitted.
     * @principle Allows public read access to user profile information.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Enforces ownership for search history entries.
     * @path /users/{userId}/searchHistory/{searchId}
     * @allow (create): Allows a user to create their own search history entry if the userId matches.
     * @allow (get, list): Allows a user to read their own search history entries.
     * @allow (update, delete): Allows a user to update/delete their own search history entries if the userId matches and the document exists.
     * @deny (create): Denies creation if the userId does not match the authenticated user's ID.
     * @deny (get, list, update, delete): Denies access if the userId does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/searchHistory/{searchId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get, list: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Enforces ownership for transaction entries.
     * @path /users/{userId}/transactions/{transactionId}
     * @allow (create): Allows a user to create their own transaction if the userId matches.
     * @allow (get, list): Allows a user to read their own transactions.
     * @allow (update, delete): Allows a user to update/delete their own transactions if the userId matches and the document exists.
     * @deny (create): Denies creation if the userId does not match the authenticated user's ID.
     * @deny (get, list, update, delete): Denies access if the userId does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/transactions/{transactionId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get, list: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Enforces ownership for learning paths.
     * @path /users/{userId}/learningPaths/{pathId}
     * @allow (create): Allows a user to create their own learning path if the userId matches.
     * @allow (get, list): Allows a user to read their own learning paths.
     * @allow (update, delete): Allows a user to update/delete their own learning paths if the userId matches and the document exists.
     * @deny (create): Denies creation if the userId does not match the authenticated user's ID.
     * @deny (get, list, update, delete): Denies access if the userId does not match the authenticated user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/learningPaths/{pathId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get, list: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Helper function to determine if the user is signed in.
     * @return True if the user is signed in, false otherwise.
     * @example isSignedIn() == true if request.auth != null
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Helper function to determine if the user is the owner of the document.
     * @param userId The user ID to compare against the authenticated user's ID.
     * @return True if the user is the owner, false otherwise.
     * @example isOwner('someUserId') == (request.auth.uid == 'someUserId')
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Helper function to determine if the user is the owner of the document and the document exists.
     * @param userId The user ID to compare against the authenticated user's ID.
     * @return True if the user is the owner and the document exists, false otherwise.
     * @example isExistingOwner('someUserId') == (request.auth.uid == 'someUserId' && resource != null)
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}