/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for personal data (profiles, search history, transactions)
 * and allows public read access to supplier data. All write operations on user-owned data are restricted to the authenticated user.
 *
 * Data Structure:
 * - /suppliers/{supplierId}: Publicly readable supplier profiles. Owner-only writes are NOT currently enforced.
 * - /users/{userId}: Public user profile information, created on user sign up.
 * - /users/{userId}/searchHistory/{searchId}: Search history for each user, accessible only by the user.
 * - /users/{userId}/transactions/{transactionId}: Financial transactions for each user, accessible only by the user.
 *
 * Key Security Decisions:
 * - Users can only access their own search history and transaction data.
 * - Suppliers are publicly readable.
 * - The rules explicitly deny any unauthorized access to user data.
 *
 * Denormalization for Authorization:
 *  - User-specific collections are nested under /users/{userId} to easily enforce ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to supplier profiles. Write access is not currently restricted.
     * @path /suppliers/{supplierId}
     * @allow (get, list) Public access to read supplier profiles.
     * @deny (create, update, delete) No write access is currently enforced.
     * @principle Public read access to supplier data.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows read access to user profiles, but only the user themselves can create, update, or delete their profile.
     * @path /users/{userId}
     * @allow (get) Any authenticated user can read a user profile.
     * @allow (create) The user with the matching UID can create their profile.
     * @deny (update, delete) Only the user with the matching UID can update or delete their profile.
     * @deny (create) Creating a profile with a mismatched user ID is not allowed.
     * @principle Enforces document ownership for writes, public read for user profiles.
     */
    match /users/{userId} {
      allow get: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isExistingOwner(userId);
      allow list: if false;
    }

    /**
     * @description Allows a user to manage their own search history entries.
     * @path /users/{userId}/searchHistory/{searchId}
     * @allow (create) The user with the matching UID can create search history entries.
     * @allow (get, list, update, delete) Only the user with the matching UID can access their search history.
     * @deny (create) Creating a search history entry with a mismatched user ID is not allowed.
     * @principle Restricts access to a user's own search history.
     */
    match /users/{userId}/searchHistory/{searchId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows a user to manage their own financial transactions.
     * @path /users/{userId}/transactions/{transactionId}
     * @allow (create) The user with the matching UID can create transactions.
     * @allow (get, list, update, delete) Only the user with the matching UID can access their transactions.
     * @deny (create) Creating a transaction with a mismatched user ID is not allowed.
     * @principle Restricts access to a user's own financial transactions.
     */
    match /users/{userId}/transactions/{transactionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}