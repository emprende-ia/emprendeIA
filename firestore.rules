
/**
 * @file Firestore Security Rules
 * @core-philosophy This ruleset enforces a strict user-ownership model for all user-generated content and public read access for general data like suppliers.
 * @data-structure
 *   - /suppliers/{supplierId}: Publicly readable supplier profiles.
 *   - /users/{userId}: Publicly readable user profiles. All subcollections are private to the user.
 *   - /users/{userId}/searchHistory/{searchId}: Private search history for each user.
 *   - /users/{userId}/transactions/{transactionId}: Private financial transactions for each user.
 *   - /users/{userId}/learningPaths/{pathId}: Private learning paths saved by each user.
 *   - /users/{userId}/marketingCampaigns/{campaignId}: Private marketing campaigns saved by each user.
 *   - /users/{userId}/notes/{noteId}: Private notes for each user.
 *   - /users/{userId}/brandIdentity/main: Private brand identity for each user.
 *   - /users/{userId}/savedSuppliers/{supplierId}: Private list of saved suppliers for each user.
 *   - /users/{userId}/viabilityAnalysis/latest: Private document for the user's latest viability analysis.
 * @key-security-decisions
 *   - User listing is disallowed to protect privacy.
 *   - Supplier data is publicly readable.
 *   - All user-owned data (subcollections under /users/{userId}) is strictly limited to the owning user.
 * @denormalization-for-authorization N/A (ownership is based on path).
 * @structural-segregation Private user data is stored under the /users/{userId} collection, while public supplier data is stored at the top level.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    /**
     * @description Allows public read access to supplier profiles. Write access is not granted in this prototype.
     * @path /suppliers/{supplierId}
     * @allow (get, list): Anyone can read supplier data.
     * @deny (create, update, delete): No one can create, update, or delete supplier data through client-side rules.
     * @principle Allows public reads, restricts writes.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read of profiles, but write access is restricted to the owner.
     * @path /users/{userId}
     * @allow (get, list): Anyone can read user profile data.
     * @allow (write): A user can create or update their own profile, but cannot change their plan status.
     * @deny (delete): Users cannot delete their profiles.
     * @principle Enforces user-ownership for profile updates while protecting subscription status.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow write: if isOwner(userId) && (resource == null || !isChangingPlan());
      allow delete: if false;
    }

    /**
     * @description Stripe Extension: Allows a user to create their own customer document.
     * @path /customers/{userId}
     * @allow (create): A user can create their own customer document in Stripe.
     * @principle User can initiate their own Stripe customer object.
     */
     match /customers/{userId} {
        allow create, write: if isOwner(userId);
     }
    
    /**
     * @description Stripe Extension: Allows a user to create a checkout session. The extension handles reads/updates.
     * @path /customers/{userId}/checkout_sessions/{sessionId}
     * @allow (create): A user can create a checkout session for themselves.
     * @principle User can initiate a payment flow.
     */
     match /customers/{userId}/checkout_sessions/{sessionId} {
        allow create: if isOwner(userId);
        allow read, write: if isOwner(userId);
     }

    /**
     * @description Enforces user-ownership for their viability analysis document.
     * @path /users/{userId}/viabilityAnalysis/latest
     * @allow (read, write): The user can manage their own analysis document.
     * @principle Enforces strict user-ownership for a singleton analysis document.
     */
    match /users/{userId}/viabilityAnalysis/latest {
        allow read, write: if isOwner(userId);
    }

    /**
     * @description Enforces that only the authenticated user can access their own search history.
     * @path /users/{userId}/searchHistory/{searchId}
     * @allow (create): The user can create a search history entry if the userId matches their auth UID.
     * @allow (get, list): The user can read their own search history entries if the userId matches their auth UID.
     * @allow (update, delete): The user can update or delete their own search history entries if the userId matches their auth UID and the document exists.
     * @deny (create, get, list, update, delete): Denies operations if the user is not authenticated or the user ID does not match the authenticated user's ID.
     * @principle Enforces user-ownership for search history.
     */
    match /users/{userId}/searchHistory/{searchId} {
      allow create: if isOwner(userId);
      allow get, list: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces that only the authenticated user can access their own financial transactions.
     * @path /users/{userId}/transactions/{transactionId}
     * @allow (create): The user can create a transaction if the userId matches their auth UID.
     * @allow (get, list): The user can read their own transactions if the userId matches their auth UID.
     * @allow (update, delete): The user can update or delete their own transactions if the userId matches their auth UID and the document exists.
     * @deny (create, get, list, update, delete): Denies operations if the user is not authenticated or the user ID does not match the authenticated user's ID.
     * @principle Enforces user-ownership for financial transactions.
     */
    match /users/{userId}/transactions/{transactionId} {
      allow create: if isOwner(userId);
      allow get, list: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }
    
    /**
     * @description Enforces that only the authenticated user can access their own notes.
     * @path /users/{userId}/notes/{noteId}
     * @allow (create): The user can create a note if the userId matches their auth UID.
     * @allow (get, list): The user can read their own notes if the userId matches their auth UID.
     * @allow (update, delete): The user can update or delete their own notes if the userId matches their auth UID and the document exists.
     * @deny (create, get, list, update, delete): Denies operations if the user is not authenticated or the user ID does not match the authenticated user's ID.
     * @principle Enforces user-ownership for notes.
     */
    match /users/{userId}/notes/{noteId} {
      allow create: if isOwner(userId);
      allow get, list: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces that only the authenticated user can access their own learning paths.
     * @path /users/{userId}/learningPaths/{pathId}
     * @allow (read, write): The user can manage their own learning paths.
     * @principle Enforces user-ownership for learning paths.
     */
    match /users/{userId}/learningPaths/{pathId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * @description Enforces that only the authenticated user can access their own marketing campaigns.
     * @path /users/{userId}/marketingCampaigns/{campaignId}
     * @allow (read, write): The user can manage their own marketing campaigns.
     * @principle Enforces user-ownership for marketing campaigns.
     */
    match /users/{userId}/marketingCampaigns/{campaignId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * @description Enforces user-ownership for their brand identity document.
     * @path /users/{userId}/brandIdentity/main
     * @allow (read, create, update, delete): The user can manage their own brand identity if the userId matches their auth UID.
     * @principle Enforces strict user-ownership for a singleton brand identity document.
     */
    match /users/{userId}/brandIdentity/main {
        allow read, create, update, delete: if isOwner(userId);
    }

    /**
     * @description Enforces that only the authenticated user can manage their saved suppliers.
     * @path /users/{userId}/savedSuppliers/{supplierId}
     * @allow (create, get, list, update, delete): The user can manage their own saved suppliers if the userId matches their auth UID.
     * @deny (create, get, list, update, delete): Denies operations if the user is not authenticated or the user ID does not match.
     * @principle Enforces user-ownership for saved suppliers.
     */
    match /users/{userId}/savedSuppliers/{supplierId} {
      allow read, write: if isOwner(userId);
    }

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // Helper function to check if a user is trying to change their plan.
    function isChangingPlan() {
      // This function is now safe for create operations where 'resource' is null.
      return resource != null && (request.resource.data.plan != resource.data.plan || request.resource.data.planStatus != resource.data.planStatus);
    }
  }
}
