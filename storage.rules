
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This is useful for displaying user-uploaded logos, which are not sensitive data.
    match /{allPaths=**} {
      allow read: if true;
    }

    // Restrict write operations to authenticated users on their own directory.
    // This rule allows a user to upload/update/delete their own logo.
    match /logos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
