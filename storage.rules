
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Rule: User can only read/write to their own folder.
    // The path contains the user's ID, which we match against their auth UID.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
