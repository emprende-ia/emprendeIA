
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read and write access to all files for any authenticated user.
    // This is suitable for this application as the files (logos) are not sensitive
    // and are segregated by user ID in the code logic.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
