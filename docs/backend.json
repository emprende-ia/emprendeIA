
{
  "entities": {
    "ViabilityAnalysis": {
      "title": "Viability Analysis",
      "description": "Represents a saved viability analysis for a user's business idea or existing business.",
      "type": "object",
      "properties": {
        "analysis": {
          "type": "object",
          "description": "The full JSON object of the AI-generated analysis."
        },
        "type": {
          "type": "string",
          "enum": ["new-venture", "existing-venture"],
          "description": "The type of analysis performed."
        },
        "savedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the analysis was saved."
        }
      },
      "required": ["analysis", "type", "savedAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "description": "URL of the user's profile picture."
        }
      },
      "required": ["displayName", "email"]
    },
    "Note": {
      "title": "Note",
      "description": "A user-created note or reminder.",
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "description": "The text content of the note."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the note was created."
        }
      },
      "required": ["content", "createdAt"]
    },
    "SearchHistory": {
      "title": "Search History",
      "description": "A record of a user's search query.",
      "type": "object",
      "properties": {
        "term": {
          "type": "string",
          "description": "The search term used by the user."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the search was performed."
        },
        "resultingKeywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Keywords generated by the AI from the search term."
        }
      },
      "required": ["term", "timestamp"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Represents a supplier in the marketplace.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The supplier's company name."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the supplier's products and services."
        },
        "location": {
          "type": "string",
          "description": "The geographic location of the supplier."
        },
        "rating": {
          "type": "number",
          "description": "The supplier's average user rating."
        },
        "category": {
          "type": "string",
          "description": "AI-generated category for the supplier (e.g., 'alimentacion', 'empaque')."
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "AI-generated keywords for semantic search."
        },
        "baseSummaryIA": {
          "type": "string",
          "description": "A generic, AI-generated summary of the supplier."
        }
      },
      "required": ["name", "description", "location"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a single financial transaction (income or expense).",
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "description": "A brief description of the transaction."
        },
        "amount": {
          "type": "number",
          "description": "The monetary value of the transaction."
        },
        "type": {
          "type": "string",
          "enum": ["income", "expense"],
          "description": "The type of transaction."
        },
        "category": {
          "type": "string",
          "description": "The financial category of the transaction (e.g., 'Ventas', 'Renta', 'Marketing')."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the transaction occurred."
        }
      },
      "required": ["description", "amount", "type", "timestamp"]
    },
    "LearningPath": {
      "title": "Learning Path",
      "description": "A personalized micro-learning path generated for a user.",
      "type": "object",
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the learning path was saved."
        },
        "pathData": {
          "type": "object",
          "description": "The full JSON data of the generated learning path."
        },
        "completedTasks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "An array of task titles that have been marked as completed."
        },
        "taskAudios": {
          "type": "object",
          "description": "A map of task titles to their generated audio data URIs.",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["createdAt", "pathData"]
    },
    "MarketingCampaign": {
      "title": "Marketing Campaign",
      "description": "An AI-generated marketing campaign plan saved by a user.",
      "type": "object",
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the campaign was saved."
        },
        "campaignIdea": {
          "type": "object",
           "description": "The initial campaign idea object."
        },
        "campaignPlan": {
          "type": "object",
          "description": "The full JSON data of the generated campaign action plan."
        },
        "completedTasks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "An array of task titles that have been marked as completed."
        },
        "taskAudios": {
          "type": "object",
          "description": "A map of task titles to their generated audio data URIs.",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["createdAt", "campaignIdea", "campaignPlan"]
    },
    "BrandIdentity": {
      "title": "Brand Identity",
      "description": "A user's saved brand identity, including name, slogan, colors, and logo.",
      "type": "object",
      "properties": {
        "brandName": {
          "type": "string"
        },
        "slogan": {
          "type": "string"
        },
        "colorPalette": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "hex": {"type": "string"},
              "name": {"type": "string"}
            }
          }
        },
        "logoPrompt": {
          "type": "string"
        },
        "logoUrl": {
          "type": "string",
          "format": "uri",
          "description": "A data URI of the generated logo image."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["brandName", "slogan", "updatedAt"]
    },
    "SavedSupplier": {
      "title": "Saved Supplier",
      "description": "A supplier profile saved by a user.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "contactInfo": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "specialOffers": {
          "type": "string"
        },
        "summaryIA": {
          "type": "string"
        },
        "savedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "description", "contactInfo", "location", "summaryIA", "savedAt"]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "facebook.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/viabilityAnalysis/latest",
        "definition": {
          "entityName": "ViabilityAnalysis",
          "schema": { "$ref": "#/entities/ViabilityAnalysis" },
          "description": "Stores the user's latest viability analysis result."
        }
      },
      {
        "path": "/suppliers/{supplierId}",
        "definition": {
          "entityName": "Supplier",
          "schema": { "$ref": "#/entities/Supplier" },
          "description": "Stores all supplier documents."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/entities/UserProfile" },
          "description": "Stores public user profile information."
        }
      },
      {
        "path": "/users/{userId}/searchHistory/{searchId}",
        "definition": {
          "entityName": "SearchHistory",
          "schema": { "$ref": "#/entities/SearchHistory" },
          "description": "Stores a user's search history for personalization."
        }
      },
       {
        "path": "/users/{userId}/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/entities/Transaction" },
          "description": "Stores a user's financial transactions."
        }
      },
      {
        "path": "/users/{userId}/notes/{noteId}",
        "definition": {
          "entityName": "Note",
          "schema": { "$ref": "#/entities/Note" },
          "description": "Stores a user's notes."
        }
      },
      {
        "path": "/users/{userId}/learningPaths/{pathId}",
        "definition": {
          "entityName": "LearningPath",
          "schema": { "$ref": "#/entities/LearningPath" },
          "description": "Stores a user's saved learning paths."
        }
      },
       {
        "path": "/users/{userId}/marketingCampaigns/{campaignId}",
        "definition": {
          "entityName": "MarketingCampaign",
          "schema": { "$ref": "#/entities/MarketingCampaign" },
          "description": "Stores a user's saved marketing campaigns."
        }
      },
      {
        "path": "/users/{userId}/brandIdentity/main",
        "definition": {
          "entityName": "BrandIdentity",
          "schema": { "$ref": "#/entities/BrandIdentity" },
          "description": "Stores the user's primary brand identity."
        }
      },
      {
        "path": "/users/{userId}/savedSuppliers/{supplierId}",
        "definition": {
          "entityName": "SavedSupplier",
          "schema": { "$ref": "#/entities/SavedSupplier" },
          "description": "Stores a user's saved supplier profiles."
        }
      }
    ]
  }
}

    