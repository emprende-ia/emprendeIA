{
  "entities": {
    "CheckoutSession": {
      "title": "Checkout Session",
      "description": "Represents a Stripe checkout session for a user.",
      "type": "object",
      "properties": {
        "price": { "type": "string" },
        "success_url": { "type": "string", "format": "uri" },
        "cancel_url": { "type": "string", "format": "uri" },
        "mode": { "type": "string", "enum": ["subscription", "payment"] },
        "status": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      },
      "required": ["price", "success_url", "cancel_url", "mode"]
    },
    "ViabilityAnalysis": {
      "title": "Viability Analysis",
      "description": "User's business viability results.",
      "type": "object",
      "properties": {
        "analysis": { "type": "object" },
        "type": { "type": "string", "enum": ["new-venture", "existing-venture"] },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["analysis", "type", "savedAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "fullName": { "type": "string" },
        "age": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "plan": { "type": "string", "enum": ["básico", "oro", "diamante"] },
        "planStatus": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["displayName", "email", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["description", "amount", "type", "timestamp"]
    },
    "LearningPath": {
      "title": "Learning Path",
      "type": "object",
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "pathData": { "type": "object" },
        "completedTasks": { "type": "array", "items": { "type": "string" } },
        "taskAudios": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["createdAt", "pathData"]
    },
    "MarketingCampaign": {
      "title": "Marketing Campaign",
      "type": "object",
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "campaignIdea": { "type": "object" },
        "campaignPlan": { "type": "object" },
        "completedTasks": { "type": "array", "items": { "type": "string" } },
        "taskAudios": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["createdAt", "campaignIdea", "campaignPlan"]
    },
    "BrandIdentity": {
      "title": "Brand Identity",
      "type": "object",
      "properties": {
        "brandName": { "type": "string" },
        "slogan": { "type": "string" },
        "colorPalette": { "type": "array", "items": { "type": "object" } },
        "logoPrompt": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["brandName", "slogan", "updatedAt"]
    }
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/users/{userId}/viabilityAnalysis/latest", "definition": { "entityName": "ViabilityAnalysis" } },
      { "path": "/users/{userId}/transactions/{transactionId}", "definition": { "entityName": "Transaction" } },
      { "path": "/users/{userId}/learningPaths/{pathId}", "definition": { "entityName": "LearningPath" } },
      { "path": "/users/{userId}/marketingCampaigns/{campaignId}", "definition": { "entityName": "MarketingCampaign" } },
      { "path": "/users/{userId}/brandIdentity/main", "definition": { "entityName": "BrandIdentity" } },
      { "path": "/customers/{userId}/checkout_sessions/{sessionId}", "definition": { "entityName": "CheckoutSession" } }
    ]
  }
}